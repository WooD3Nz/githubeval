pipeline {
    agent any

    stages {
        stage('clear workspace') {
            steps {
                cleanWs()
            }
        }
        stage('checkout SCM') {
            steps {
                sh "git clone https://github.com/WooD3Nz/githubeval.git"
            }
        }
        stage('install docker') {
            steps {
                sh '''
                    sudo apt update
                    sudo apt upgrade -y
                    sudo apt install ca-certificates curl gnupg lsb-release -y

                    sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /tmp/docker.gpg
                    sudo gpg --batch --yes --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg /tmp/docker.gpg

                    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] \
                    https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
                    | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

                    sudo apt update
                    sudo apt install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin -y
                    
                    sudo chmod 666 /var/run/docker.sock
                    sudo usermod -aG docker $USER
                    
                    sudo docker run hello-world
                '''
            }
        }
        stage('suppression image et container') {
            steps {
                sh '''
                    docker rm -f $(docker ps -aq)
                    docker rmi -f $(docker images -q)
                '''
            }
        }
        stage('docker build image nginx') {
            steps {
                dir('githubeval') {        
                    sh 'docker build -t my-nginx .'
              }
          }
          stage('docker create nginx container') {
            steps {
                sh '''
                    docker run -d --name myapp --hostname myapp -v volumemyapp:/var/www/html --ip 192.168.10.100 mon-nginx:latest
                    docker ps
                    docker exec myapp /etc/init.d/nginx start
                '''
            }
        }
        stage('copy-fichiers-monsite') {
            steps {
                sh '''
                    docker cp ./monsite/. myapp:/var/www/html/
                    docker exec myapp ls -la /var/www/html
                '''
             }
          }
      }
  }
}
